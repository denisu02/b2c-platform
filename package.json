{
  "name": "b2c-platform",
  "private": true,
  "scripts": {
    "dev": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "lint": "npm --prefix client run lint",
    "lint:staged": "npm --prefix client run lint:staged",
    "typecheck": "npm --prefix client run typecheck",
    "prettier:check": "node client/node_modules/prettier/bin/prettier.cjs --config .prettierrc --ignore-path .prettierignore --check \"client/**/*.{js,jsx,ts,tsx,json,css,scss,md,html}\" \"server/**/*.{json,md}\"",
    "prettier:write": "node client/node_modules/prettier/bin/prettier.cjs --config .prettierrc --ignore-path .prettierignore --write \"client/**/*.{js,jsx,ts,tsx,json,css,scss,md,html}\" \"server/**/*.{json,md}\"",
    "verify": "npm run typecheck && npm run lint && npm run prettier:check",
    "server": "npm --prefix client run server"
  }
}
